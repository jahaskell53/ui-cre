SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

APIFY_API_TOKEN=your-apify-api-token
APIFY_ACTOR_ID=maxcopell/zillow-zip-code-search
APIFY_DETAIL_ACTOR_ID=your-zillow-detail-actor-id

SENDGRID_API_KEY=your-sendgrid-api-key
ALERT_EMAIL=your-email@example.com
SMTP_FROM=hello@yourdomain.com

# AWS S3 (used by download_om_pdfs asset to store OM PDFs)
ACCESS_KEY=your-aws-access-key
SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# Mapbox — used by backfill_loopnet_geom_job to geocode listings without coordinates.
# Falls back to the hardcoded public token if not set.
MAPBOX_TOKEN=your-mapbox-public-token

# Used by extract_om_metrics asset to call Gemini 2.5 Flash for PDF metric extraction
GEMINI_API_KEY=your-gemini-api-key

# Used by crexi_cap_rate_backfill_job to authenticate with the Crexi detail API.
# Extract from an authenticated Chrome session: DevTools → Network → any
# /assets or /universal-search request → Authorization: Bearer <token>.
# Can also be supplied per-run via the Dagster UI Launchpad (bearer_token field).
CREXI_BEARER_TOKEN=your-crexi-bearer-token

# Used by seed scripts only (not by the Dagster pipeline itself)
DATABASE_URL=postgresql://postgres.your-project:your-password@aws-1-us-east-2.pooler.supabase.com:5432/postgres
